# ===========================================
# LOCAL DEVELOPMENT (SQLite)
# ===========================================
# DATABASE_URL="file:./dev.db"

# ===========================================
# PRODUCTION (Vercel Postgres)
# ===========================================
# These values are automatically provided by Vercel when you add a Postgres database
# DATABASE_URL="postgres://default:xxxxx@xxxxx.postgres.vercel-storage.com/verceldb?pgbouncer=true&connect_timeout=15"
# DIRECT_DATABASE_URL="postgres://default:xxxxx@xxxxx.postgres.vercel-storage.com/verceldb?connect_timeout=15"

# ===========================================
# VERCEL BLOB STORAGE
# ===========================================
# Get this token from Vercel Dashboard > Storage > Blob > Create Store
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxx"

# ===========================================
# NEXT.JS CONFIGURATION
# ===========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================================
# UPLOAD CONFIGURATION (Local only)
# ===========================================
MAX_FILE_SIZE=5242880
UPLOAD_DIR="./public/images"
